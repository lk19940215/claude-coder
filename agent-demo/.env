BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_API_KEY=sk-sp-

# 模型路由配置（可在 .claude-coder/.env 修改）
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3-max-2026-01-23
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3-coder-next
FALLBACK_MODEL=qwen3-coder-plus
DEFAULT_MODEL=glm-5

# Agent 调试模式（写入 logs/ 目录）
# 注意: 不要用 DEBUG=true，会触发 Anthropic SDK 自己的详细日志输出
# DEBUG === 'true';
AGENT_DEBUG=true