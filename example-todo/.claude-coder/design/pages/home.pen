                          ]
                        },
                        {
                          "type": "text",
                          "id": "task-drag-1",
                          "fill": "$sys:color.text-muted",
                          "content": "⋮⋮",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "task-item-2",
                      "width": "fill_container",
                      "height": 76,
                      "fill": "$sys:color.bg-card",
                      "stroke": { "align": "inside", "thickness": 1, "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E","position":0},{"color":"#D4A574","position":1}], "rotation": 135 } },
                      "cornerRadius": 12,
                      "padding": [16, 20],
                      "gap": 16,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "frame",
                          "id": "task-checkbox-2",
                          "width": 24,
                          "height": 24,
                          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E","position":0},{"color":"#D4A574","position":1}], "rotation": 135 },
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "task-check-icon-2", "fill": "#FFFFFF", "content": "✓", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "700" }
