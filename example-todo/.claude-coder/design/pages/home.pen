{
  "version": "2.9",
  "imports": { "sys": "../system.lib.pen" },
  "children": [
    {
      "type": "frame",
      "id": "page-root",
      "x": 0,
      "y": 0,
      "width": 1440,
      "fill": "$sys:color.bg",
      "layout": "vertical",
      "children": [
        {
          "type": "ref",
          "id": "section-header",
          "ref": "sys:header",
          "descendants": {
            "sys:header-logo": { "content": "FlowTask" },
            "sys:nav-link-1": { "content": "功能" },
            "sys:nav-link-2": { "content": "统计" },
            "sys:nav-link-3": { "content": "设置" }
          }
        },
        {
          "type": "frame",
          "id": "section-hero",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 16,
          "padding": [64, 120],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "hero-badge",
              "width": 160,
              "height": 32,
              "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E33","position":0},{"color":"#D4A57433","position":1}], "rotation": 135 },
              "stroke": { "align": "inside", "thickness": 1, "fill": "#7CB68E55" },
              "cornerRadius": 16,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "hero-badge-text", "fill": "#5A9A6D", "content": "✨ 专注效率工具", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "500" }
              ]
            },
            { "type": "text", "id": "hero-title", "fill": "$sys:color.text", "content": "让每一天都有条不紊", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 48, "fontWeight": "700", "textAlign": "center" },
            { "type": "text", "id": "hero-subtitle", "fill": "$sys:color.text-muted", "content": "智能任务管理 + 番茄钟专注法，助你高效完成每一件事", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "textAlign": "center", "textGrowth": "fixed-width", "width": 500 }
          ]
        },
        {
          "type": "frame",
          "id": "section-workspace",
          "width": "fill_container",
          "padding": [0, 80, 80],
          "gap": 24,
          "children": [
            {
              "type": "frame",
              "id": "sidebar",
              "layout": "vertical",
              "gap": 16,
              "width": 220,
              "children": [
                {
                  "type": "frame",
                  "id": "sidebar-header",
                  "width": "fill_container",
                  "padding": [0, 0, 8, 0],
                  "stroke": { "align": "inside", "thickness": 1, "fill": "$sys:color.border" },
                  "children": [
                    { "type": "text", "id": "sidebar-header-title", "fill": "$sys:color.text-muted", "content": "📂 分类标签", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "500" }
                  ]
                },
                {
                  "type": "frame",
                  "id": "sidebar-tags",
                  "layout": "vertical",
                  "gap": 4,
                  "width": "fill_container",
                  "children": [
                    {
                      "type": "frame",
                      "id": "tag-all",
                      "width": "fill_container",
                      "height": 44,
                      "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E33","position":0},{"color":"#D4A57433","position":1}], "rotation": 135 },
                      "cornerRadius": 8,
                      "padding": [0, 12],
                      "gap": 10,
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "tag-all-icon", "fill": "#5A9A6D", "content": "📋", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16 },
                        { "type": "text", "id": "tag-all-label", "fill": "$sys:color.text", "content": "全部任务", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                        {
                          "type": "frame",
                          "id": "tag-all-count",
                          "width": 28,
                          "height": 22,
                          "fill": "#7CB68E",
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "tag-all-count-num", "fill": "#FFFFFF", "content": "8", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 11, "fontWeight": "600" }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tag-work",
                      "width": "fill_container",
                      "height": 44,
                      "fill": "$sys:color.bg-card",
                      "cornerRadius": 8,
                      "padding": [0, 12],
                      "gap": 10,
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "tag-work-icon", "fill": "$sys:color.text-muted", "content": "💼", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16 },
                        { "type": "text", "id": "tag-work-label", "fill": "$sys:color.text-muted", "content": "工作", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                        {
                          "type": "frame",
                          "id": "tag-work-count",
                          "width": 28,
                          "height": 22,
                          "fill": "$sys:color.bg-elevated",
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "tag-work-count-num", "fill": "$sys:color.text-muted", "content": "3", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 11 }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tag-personal",
                      "width": "fill_container",
                      "height": 44,
                      "fill": "$sys:color.bg-card",
                      "cornerRadius": 8,
                      "padding": [0, 12],
                      "gap": 10,
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "tag-personal-icon", "fill": "$sys:color.text-muted", "content": "🏠", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16 },
                        { "type": "text", "id": "tag-personal-label", "fill": "$sys:color.text-muted", "content": "个人", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                        {
                          "type": "frame",
                          "id": "tag-personal-count",
                          "width": 28,
                          "height": 22,
                          "fill": "$sys:color.bg-elevated",
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "tag-personal-count-num", "fill": "$sys:color.text-muted", "content": "2", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 11 }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tag-study",
                      "width": "fill_container",
                      "height": 44,
                      "fill": "$sys:color.bg-card",
                      "cornerRadius": 8,
                      "padding": [0, 12],
                      "gap": 10,
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "tag-study-icon", "fill": "$sys:color.text-muted", "content": "📚", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16 },
                        { "type": "text", "id": "tag-study-label", "fill": "$sys:color.text-muted", "content": "学习", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
                        {
                          "type": "frame",
                          "id": "tag-study-count",
                          "width": 28,
                          "height": 22,
                          "fill": "$sys:color.bg-elevated",
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "tag-study-count-num", "fill": "$sys:color.text-muted", "content": "3", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 11 }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tag-add",
                      "width": "fill_container",
                      "height": 44,
                      "fill": "$sys:color.bg-card",
                      "stroke": { "align": "inside", "thickness": 1, "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E","position":0},{"color":"#D4A574","position":1}], "rotation": 135 }, "thickness": 1 },
                      "cornerRadius": 8,
                      "padding": [0, 12],
                      "gap": 10,
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "tag-add-icon", "fill": "#5A9A6D", "content": "+", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16, "fontWeight": "600" },
                        { "type": "text", "id": "tag-add-label", "fill": "#5A9A6D", "content": "新建标签", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "sidebar-stats",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 16,
                  "fill": "$sys:color.bg-card",
                  "stroke": { "align": "inside", "thickness": 1, "fill": "$sys:color.border" },
                  "cornerRadius": 12,
                  "children": [
                    { "type": "text", "id": "stats-title", "fill": "$sys:color.text", "content": "📊 本周统计", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13, "fontWeight": "600" },
                    {
                      "type": "frame",
                      "id": "stats-item-1",
                      "width": "fill_container",
                      "justifyContent": "space_between",
                      "children": [
                        { "type": "text", "id": "stats-label-1", "fill": "$sys:color.text-muted", "content": "已完成", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 },
                        { "type": "text", "id": "stats-value-1", "fill": "$sys:color.success", "content": "12", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "600" }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "stats-item-2",
                      "width": "fill_container",
                      "justifyContent": "space_between",
                      "children": [
                        { "type": "text", "id": "stats-label-2", "fill": "$sys:color.text-muted", "content": "进行中", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 },
                        { "type": "text", "id": "stats-value-2", "fill": "#5A9A6D", "content": "8", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "600" }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "stats-item-3",
                      "width": "fill_container",
                      "justifyContent": "space_between",
                      "children": [
                        { "type": "text", "id": "stats-label-3", "fill": "$sys:color.text-muted", "content": "番茄钟", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 },
                        { "type": "text", "id": "stats-value-3", "fill": "#F59E0B", "content": "24", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "600" }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "task-list-area",
              "layout": "vertical",
              "gap": 16,
              "width": "fill_container",
              "children": [
                {
                  "type": "frame",
                  "id": "task-list-header",
                  "width": "fill_container",
                  "justifyContent": "space_between",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "task-list-title-group",
                      "gap": 12,
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "task-list-title", "fill": "$sys:color.text", "content": "我的任务", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "600" },
                        {
                          "type": "frame",
                          "id": "task-count-badge",
                          "width": 32,
                          "height": 24,
                          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E","position":0},{"color":"#D4A574","position":1}], "rotation": 135 },
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "task-count-num", "fill": "#FFFFFF", "content": "8", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "600" }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "task-actions",
                      "gap": 12,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "frame",
                          "id": "btn-filter",
                          "width": 100,
                          "height": 36,
                          "fill": "$sys:color.bg-card",
                          "stroke": { "align": "inside", "thickness": 1, "fill": "$sys:color.border" },
                          "cornerRadius": 8,
                          "padding": [0, 12],
                          "gap": 6,
                          "alignItems": "center",
                          "children": [
                            { "type": "text", "id": "btn-filter-icon", "fill": "$sys:color.text-muted", "content": "↓", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 },
                            { "type": "text", "id": "btn-filter-label", "fill": "$sys:color.text-muted", "content": "排序", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13 }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "btn-add-task-main",
                          "width": 120,
                          "height": 36,
                          "fill": { "type": "gradient", "gradientType": "linear", "enabled": true, "colors": [{"color":"#7CB68E","position":0},{"color":"#D4A574","position":1}], "rotation": 135 },
                          "cornerRadius": 8,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "gap": 6,
                          "children": [
                            { "type": "text", "id": "btn-add-task-main-icon", "fill": "#FFFFFF", "content": "+", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                            { "type": "text", "id": "btn-add-task-main-label", "fill": "#FFFFFF", "content": "添加任务", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13, "fontWeight": "500" }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "task-list",
                  "layout": "vertical",
                  "gap": 12,
                  "width": "fill_container",
                  "children": [
                    {
                      "type": "frame",
                      "id": "task-item-1",
                      "width": "fill_container",
                      "height": 76,
                      "fill": "$sys:color.bg-card",
                      "stroke": { "align": "inside", "thickness": 1, "fill": "$sys:color.border" },
                      "cornerRadius": 12,
                      "padding": [16, 20],
                      "gap": 16,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "frame",
                          "id": "task-checkbox-1",
                          "width": 24,
                          "height": 24,
                          "fill": "$sys:color.bg",
                          "stroke": { "align": "inside", "thickness": 2, "fill": "$sys:color.border" },
                          "cornerRadius": 6,
                          "justifyContent": "center",
                          "alignItems": "center"
                        },
                        {
                          "type": "frame",
                          "id": "task-content-1",
                          "layout": "vertical",
                          "gap": 4,
                          "width": "fill_container",
                          "children": [
                            { "type": "text", "id": "task-title-1", "fill": "$sys:color.text", "content": "完成项目设计文档", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16, "fontWeight": "500" },
                            { "type": "text", "id": "task-desc-1", "fill": "$sys:color.text-muted", "content": "整理需求，输出设计稿和技术方案", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "task-tag-1",
                          "width": 60,
                          "height": 24,
                          "fill": "#7CB68E33",
                          "cornerRadius": 12,
                          "justifyContent": "center",
                          "alignItems": "center",
