{
  "version": "2.9",
  "children": [
    {
      "type": "frame",
      "id": "header",
      "x": 0,
      "y": 0,
      "reusable": true,
      "width": 1440,
      "height": 64,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "padding": [0, 32],
      "justifyContent": "space_between",
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "header-left",
          "gap": 12,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "header-logo-icon",
              "width": 32,
              "height": 32,
              "fill": "$color.primary",
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "header-logo-symbol", "fill": "#FFFFFF", "content": "✓", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
              ]
            },
            { "type": "text", "id": "header-logo", "fill": "$color.text", "content": "FlowTask", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "700" }
          ]
        },
        {
          "type": "frame",
          "id": "header-nav",
          "gap": 24,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "nav-link-1", "fill": "$color.text-muted", "content": "功能", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-link-2", "fill": "$color.text-muted", "content": "统计", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "nav-link-3", "fill": "$color.text-muted", "content": "设置", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
          ]
        },
        {
          "type": "frame",
          "id": "header-actions",
          "gap": 12,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "btn-add-task",
              "width": 120,
              "height": 40,
              "fill": "$color.primary",
              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "btn-add-task-label", "fill": "#FFFFFF", "content": "+ 新任务", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "btn-primary",
      "x": 0,
      "y": 100,
      "reusable": true,
      "width": 160,
      "height": 48,
      "fill": "$color.primary",
      "cornerRadius": 12,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "btn-primary-label", "fill": "#FFFFFF", "content": "按钮", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16, "fontWeight": "600" }
      ]
    },
    {
      "type": "frame",
      "id": "btn-secondary",
      "x": 200,
      "y": 100,
      "reusable": true,
      "width": 120,
      "height": 40,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "btn-secondary-label", "fill": "$color.text", "content": "次按钮", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "500" }
      ]
    },
    {
      "type": "frame",
      "id": "task-item",
      "x": 0,
      "y": 180,
      "reusable": true,
      "width": 680,
      "height": 72,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 12,
      "padding": [16, 20],
      "gap": 16,
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "task-checkbox",
          "width": 24,
          "height": 24,
          "fill": "$color.bg",
          "stroke": { "align": "inside", "thickness": 2, "fill": "$color.primary" },
          "cornerRadius": 6,
          "justifyContent": "center",
          "alignItems": "center"
        },
        {
          "type": "frame",
          "id": "task-content",
          "layout": "vertical",
          "gap": 4,
          "width": "fill_container",
          "children": [
            { "type": "text", "id": "task-title", "fill": "$color.text", "content": "任务标题占位", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16, "fontWeight": "500" },
            { "type": "text", "id": "task-desc", "fill": "$color.text-muted", "content": "任务描述占位", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 }
          ]
        },
        {
          "type": "frame",
          "id": "task-tag",
          "width": 64,
          "height": 24,
          "fill": "$color.primary-light",
          "cornerRadius": 12,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "task-tag-label", "fill": "$color.primary-dark", "content": "工作", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 11, "fontWeight": "500" }
          ]
        },
        {
          "type": "text",
          "id": "task-drag",
          "fill": "$color.text-muted",
          "content": "⋮⋮",
          "fontFamily": "Inter, system-ui, sans-serif",
          "fontSize": 14
        }
      ]
    },
    {
      "type": "frame",
      "id": "tag-pill",
      "x": 0,
      "y": 280,
      "reusable": true,
      "width": 100,
      "height": 32,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 16,
      "padding": [0, 12],
      "gap": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "tag-dot",
          "width": 8,
          "height": 8,
          "fill": "$color.primary",
          "cornerRadius": 4
        },
        { "type": "text", "id": "tag-label", "fill": "$color.text", "content": "标签名", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 }
      ]
    },
    {
      "type": "frame",
      "id": "tag-pill-active",
      "x": 120,
      "y": 280,
      "reusable": true,
      "width": 100,
      "height": 32,
      "fill": "$color.primary-light",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.primary" },
      "cornerRadius": 16,
      "padding": [0, 12],
      "gap": 8,
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "tag-dot-active",
          "width": 8,
          "height": 8,
          "fill": "$color.primary",
          "cornerRadius": 4
        },
        { "type": "text", "id": "tag-label-active", "fill": "$color.primary-dark", "content": "标签名", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 }
      ]
    },
    {
      "type": "frame",
      "id": "pomodoro-timer",
      "x": 0,
      "y": 340,
      "reusable": true,
      "width": 280,
      "height": 360,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 16,
      "layout": "vertical",
      "gap": 24,
      "padding": 24,
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "pomodoro-title", "fill": "$color.text", "content": "番茄钟", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16, "fontWeight": "600" },
        {
          "type": "frame",
          "id": "pomodoro-circle",
          "width": 180,
          "height": 180,
          "fill": "$color.bg",
          "stroke": { "align": "inside", "thickness": 6, "fill": "$color.primary" },
          "cornerRadius": 90,
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "pomodoro-time", "fill": "$color.text", "content": "25:00", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 36, "fontWeight": "700" }
          ]
        },
        {
          "type": "frame",
          "id": "pomodoro-controls",
          "gap": 16,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "pomodoro-btn-start",
              "width": 140,
              "height": 44,
              "fill": "$color.primary",
              "cornerRadius": 22,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "pomodoro-btn-start-label", "fill": "#FFFFFF", "content": "开始专注", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "pomodoro-stats",
          "gap": 24,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "pomodoro-stat", "fill": "$color.text-muted", "content": "今日已完成 0 个番茄", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12 }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "sidebar-section",
      "x": 0,
      "y": 720,
      "reusable": true,
      "width": 200,
      "height": 300,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 12,
      "layout": "vertical",
      "gap": 8,
      "padding": 16,
      "children": [
        { "type": "text", "id": "sidebar-title", "fill": "$color.text-muted", "content": "分类标签", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 12, "fontWeight": "500" },
        {
          "type": "frame",
          "id": "sidebar-item-all",
          "width": "fill_container",
          "height": 40,
          "fill": "$color.primary-light",
          "cornerRadius": 8,
          "padding": [0, 12],
          "gap": 8,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "sidebar-item-all-icon", "fill": "$color.primary-dark", "content": "📋", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "sidebar-item-all-label", "fill": "$color.text", "content": "全部任务", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
          ]
        },
        {
          "type": "frame",
          "id": "sidebar-item",
          "width": "fill_container",
          "height": 40,
          "fill": "$color.bg",
          "cornerRadius": 8,
          "padding": [0, 12],
          "gap": 8,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "sidebar-item-icon", "fill": "$color.text-muted", "content": "💼", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 },
            { "type": "text", "id": "sidebar-item-label", "fill": "$color.text-muted", "content": "工作", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "input-field",
      "x": 0,
      "y": 1040,
      "reusable": true,
      "width": 400,
      "height": 48,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "cornerRadius": 8,
      "padding": [0, 16],
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "input-placeholder", "fill": "$color.text-muted", "content": "输入框占位文字...", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14 }
      ]
    },
    {
      "type": "frame",
      "id": "modal-overlay",
      "x": 0,
      "y": 1100,
      "reusable": true,
      "width": 1440,
      "height": 900,
      "fill": "#3D3D3D66",
      "justifyContent": "center",
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "modal-content",
          "width": 480,
          "height": 400,
          "fill": "$color.bg-card",
          "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 24,
          "padding": 32,
          "children": [
            {
              "type": "frame",
              "id": "modal-header",
              "width": "fill_container",
              "justifyContent": "space_between",
              "alignItems": "center",
              "children": [
                { "type": "text", "id": "modal-title", "fill": "$color.text", "content": "弹窗标题", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 20, "fontWeight": "600" },
                { "type": "text", "id": "modal-close", "fill": "$color.text-muted", "content": "✕", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 16 }
              ]
            },
            { "type": "frame", "id": "modal-body-placeholder", "width": "fill_container", "height": "fill_container", "fill": "$color.bg", "cornerRadius": 8 }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "footer",
      "x": 0,
      "y": 2020,
      "reusable": true,
      "width": 1440,
      "height": 200,
      "fill": "$color.bg-card",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
      "layout": "vertical",
      "gap": 24,
      "padding": [32, 80],
      "children": [
        {
          "type": "frame",
          "id": "footer-main",
          "width": "fill_container",
          "gap": 80,
          "children": [
            {
              "type": "frame",
              "id": "footer-brand-col",
              "layout": "vertical",
              "gap": 12,
              "width": "fill_container",
              "children": [
                {
                  "type": "frame",
                  "id": "footer-logo-group",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "footer-logo-icon",
                      "width": 32,
                      "height": 32,
                      "fill": "$color.primary",
                      "cornerRadius": 8,
                      "justifyContent": "center",
                      "alignItems": "center",
                      "children": [
                        { "type": "text", "id": "footer-logo-symbol", "fill": "#FFFFFF", "content": "✓", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
                      ]
                    },
                    { "type": "text", "id": "footer-brand", "fill": "$color.text", "content": "FlowTask", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 18, "fontWeight": "700" }
                  ]
                },
                { "type": "text", "id": "footer-desc", "fill": "$color.text-muted", "content": "专注高效，让时间为你所用", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "textGrowth": "fixed-width", "width": 280 }
              ]
            },
            {
              "type": "frame",
              "id": "footer-links-col",
              "layout": "vertical",
              "gap": 8,
              "width": "fill_container",
              "children": [
                { "type": "text", "id": "footer-links-title", "fill": "$color.text", "content": "功能", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                { "type": "text", "id": "footer-link-1", "fill": "$color.text-muted", "content": "任务管理", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13 },
                { "type": "text", "id": "footer-link-2", "fill": "$color.text-muted", "content": "番茄钟", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13 },
                { "type": "text", "id": "footer-link-3", "fill": "$color.text-muted", "content": "数据统计", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13 }
              ]
            },
            {
              "type": "frame",
              "id": "footer-about-col",
              "layout": "vertical",
              "gap": 8,
              "width": "fill_container",
              "children": [
                { "type": "text", "id": "footer-about-title", "fill": "$color.text", "content": "关于", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 14, "fontWeight": "600" },
                { "type": "text", "id": "footer-about-1", "fill": "$color.text-muted", "content": "关于我们", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13 },
                { "type": "text", "id": "footer-about-2", "fill": "$color.text-muted", "content": "隐私政策", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13 }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "footer-bottom",
          "width": "fill_container",
          "stroke": { "align": "inside", "thickness": 1, "fill": "$color.border" },
          "padding": [16, 0, 0, 0],
          "justifyContent": "center",
          "children": [
            { "type": "text", "id": "footer-copyright", "fill": "$color.text-muted", "content": "© 2026 FlowTask. All rights reserved.", "fontFamily": "Inter, system-ui, sans-serif", "fontSize": 13, "textAlign": "center" }
          ]
        }
      ]
    }
  ],
  "themes": { "mode": ["light", "dark"] },
  "variables": {
    "color.primary": { "type": "color", "value": "#7CB68E" },
    "color.primary-light": { "type": "color", "value": "#E8F3EC" },
    "color.primary-dark": { "type": "color", "value": "#5A9A6D" },
    "color.accent": { "type": "color", "value": "#D4A574" },
    "color.accent-light": { "type": "color", "value": "#F5EBE0" },
    "color.bg": { "type": "color", "value": "#FAF7F2" },
    "color.bg-card": { "type": "color", "value": "#FFFFFF" },
    "color.bg-elevated": { "type": "color", "value": "#F5F0E6" },
    "color.text": { "type": "color", "value": "#3D3D3D" },
    "color.text-muted": { "type": "color", "value": "#8B8578" },
    "color.border": { "type": "color", "value": "#E8E4DC" },
    "color.success": { "type": "color", "value": "#6BBF8A" },
    "color.warning": { "type": "color", "value": "#E8B96D" },
    "color.danger": { "type": "color", "value": "#D4847A" },
    "spacing.sm": { "type": "number", "value": 8 },
    "spacing.md": { "type": "number", "value": 16 },
    "spacing.lg": { "type": "number", "value": 24 },
    "spacing.xl": { "type": "number", "value": 32 },
    "spacing.2xl": { "type": "number", "value": 48 },
    "radius.md": { "type": "number", "value": 8 },
    "radius.lg": { "type": "number", "value": 12 },
    "radius.xl": { "type": "number", "value": 16 },
    "radius.full": { "type": "number", "value": 9999 },
    "font.primary": { "type": "string", "value": "Inter, system-ui, sans-serif" }
  }
}